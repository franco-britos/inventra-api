// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// =======================
// ENUMS
// =======================

enum SiteType {
  warehouse
  store
  vehicle

  @@map("SiteType")
}

enum EmployeeRole {
  owner
  manager
  staff
}

enum TransactionType {
  sale
  purchase
  adjustment
  return
  transfer
}

enum PaymentMethod {
  cash
  card
  money_order
}

// =======================
// COMPANY
// =======================

model Company {
  id          String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName String @map("company_name") @db.VarChar

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  sites                 Site[]
  employees             Employee[]
  products              Product[]
  inventories           Inventory[]
  inventoryTransactions InventoryTransaction[]
  clients               Client[]
  invites               Invite[]

  @@map("company")
}

// =======================
// APP USER (AUTH)
// =======================

model AppUser {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  email                  String    @unique @db.VarChar
  passwordHash           String?   @map("password_hash") @db.VarChar
  emailVerified          Boolean   @default(false) @map("email_verified")
  isActive               Boolean   @default(true) @map("is_active")

  lastLoginAt            DateTime? @map("last_login_at") @db.Timestamptz
  passwordResetToken     String?   @map("password_reset_token") @db.VarChar
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at") @db.Timestamptz

  mfaTotpEnabled        Boolean   @default(false) @map("mfa_totp_enabled")
  mfaTotpSecret         String?   @map("mfa_totp_secret") @db.VarChar
  mfaEmailEnabled       Boolean   @default(false) @map("mfa_email_enabled")
  mfaEmailCode          String?   @map("mfa_email_code") @db.VarChar
  mfaEmailCodeExpiresAt DateTime? @map("mfa_email_code_expires_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  employees Employee[]

  @@index([passwordResetToken])
  @@map("app_user")
}

// =======================
// SITE
// =======================

model Site {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  companyId    String       @map("company_id") @db.Uuid
  address      String       @db.VarChar
  unit         String?      @db.VarChar
  city         String?      @db.VarChar
  state        String?      @db.VarChar
  zipCode      String?      @map("zip_code") @db.VarChar
  country      String?      @db.VarChar
  placeId      String?      @map("place_id") @db.VarChar
  vin          String?      @db.VarChar
  driverName   String?      @map("driver_name") @db.VarChar
  licensePlate String?      @map("license_plate") @db.VarChar
  shortDescription String?  @map("short_description") @db.VarChar
  siteType SiteType @map("site_type")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees   Employee[]
  inventories Inventory[]

  @@index([companyId])
  @@map("site")
}

// =======================
// EMPLOYEE (USER <-> COMPANY)
// =======================

model Employee {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  userId     String  @map("user_id") @db.Uuid
  companyId  String  @map("company_id") @db.Uuid
  siteId String? @map("site_id") @db.Uuid

  firstName String       @map("first_name") @db.VarChar
  lastName  String       @map("last_name") @db.VarChar
  role      EmployeeRole @default(staff)

  isActive Boolean   @default(true) @map("is_active")
  endedAt  DateTime? @map("ended_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user     AppUser   @relation(fields: [userId], references: [id], onDelete: Cascade)
  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  site Site? @relation(fields: [siteId], references: [id], onDelete: SetNull)

  inventoryTransactions InventoryTransaction[]

  @@unique([userId, companyId])
  @@index([siteId])
  @@map("employee")
}

// =======================
// PRODUCT (COMPANY-WIDE)
// =======================

model Product {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  companyId   String    @map("company_id") @db.Uuid
  productName String    @map("product_name") @db.VarChar
  sku         String    @db.VarChar
  price             Decimal   @db.Decimal(10, 2)
  description       String?   @db.Text
  lowStockThreshold Int       @default(10) @map("low_stock_threshold")
  archivedAt        DateTime? @map("archived_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventories Inventory[]

  @@unique([companyId, sku])
  @@unique([companyId, productName])
  @@map("product")
}

// =======================
// INVENTORY (PER SITE)
// =======================

model Inventory {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  productId String @map("product_id") @db.Uuid
  siteId    String @map("site_id") @db.Uuid
  companyId String @map("company_id") @db.Uuid
  quantity        Int
  averageUnitCost Decimal @default(0) @map("average_unit_cost") @db.Decimal(10, 2)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  site    Site    @relation(fields: [siteId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id])

  inventoryTransactions InventoryTransaction[]

  @@unique([productId, siteId])
  @@map("inventory")
}

// =======================
// INVENTORY TRANSACTIONS
// =======================

model InventoryTransaction {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  inventoryId     String          @map("inventory_id") @db.Uuid
  companyId       String          @map("company_id") @db.Uuid
  employeeId      String?         @map("employee_id") @db.Uuid
  clientId        String?         @map("client_id") @db.Uuid
  transactionType TransactionType @map("transaction_type")

  quantityChange    Int      @map("quantity_change")
  unitCost          Decimal? @map("unit_cost") @db.Decimal(10, 2)
  costBasisUnitCost Decimal? @map("cost_basis_unit_cost") @db.Decimal(10, 2)
  cogsAmount        Decimal? @map("cogs_amount") @db.Decimal(10, 2)
  reference         String?  @db.VarChar
  notes             String?  @db.Text

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Restrict)
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employee  Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([inventoryId])
  @@index([companyId])
  @@index([employeeId])
  @@index([clientId])
  @@index([createdAt])
  @@map("inventory_transaction")
}

// =======================
// CLIENT
// =======================

model Client {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  companyId             String        @map("company_id") @db.Uuid
  businessName          String        @map("business_name") @db.VarChar
  businessStoreId       String        @map("business_store_id") @db.VarChar
  address               String        @db.VarChar
  pointOfContactName    String        @map("point_of_contact_name") @db.VarChar
  phoneNumber           String        @map("phone_number") @db.VarChar
  email                 String        @db.VarChar
  preferredPaymentMethod PaymentMethod @map("preferred_payment_method")
  paymentPreference     String        @map("payment_preference") @db.VarChar
  archivedAt            DateTime?     @map("archived_at") @db.Timestamptz

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  company               Company              @relation(fields: [companyId], references: [id], onDelete: Cascade)
  inventoryTransactions InventoryTransaction[]

  @@index([companyId])
  @@index([businessStoreId])
  @@unique([companyId, businessStoreId])
  @@map("client")
}

// =======================
// INVITE
// =======================

model Invite {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String       @map("company_id") @db.Uuid
  email      String       @db.VarChar
  role       EmployeeRole
  firstName  String       @map("first_name") @db.VarChar
  lastName   String       @map("last_name") @db.VarChar
  token      String       @unique @db.VarChar
  expiresAt  DateTime     @map("expires_at") @db.Timestamptz
  acceptedAt DateTime?    @map("accepted_at") @db.Timestamptz
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
  @@map("invite")
}
