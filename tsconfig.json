{
  "compilerOptions": {
    // No emit — tsx handles execution, tsc is for type-checking only
    "noEmit": true,

    // Environment Settings
    "module": "CommonJS",
    "target": "ES2020",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "types": ["node"],

    // Strict Typechecking
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "prisma", "generated", "tests"]
}
